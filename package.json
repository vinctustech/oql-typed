{
  "name": "oql-typed-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for @vinctus/oql-typed and its documentation site",
  "scripts": {
    "build": "pnpm --filter @vinctus/oql-typed build",
    "test": "pnpm --filter @vinctus/oql-typed test",
    "lint": "pnpm --filter @vinctus/oql-typed lint",
    "publish": "pnpm --filter @vinctus/oql-typed publish",
    "docs:dev": "pnpm --filter oql-typed-docs dev",
    "docs:build": "pnpm --filter oql-typed-docs build",
    "docs:preview": "pnpm --filter oql-typed-docs preview"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.12"
  }
}
